# ==========================================
# WISDOM APP — Backend Environment Variables
# ==========================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://wisdom:wisdom_dev_password@localhost:5432/wisdom_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# JWT signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# --- Sentry ---
# Get your DSN from https://sentry.io
SENTRY_DSN=

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- LiteLLM / AI ---
LITELLM_API_KEY=
LITELLM_MODEL=gpt-4o

# --- Encryption ---
# AES-256 key, 32 bytes, base64-encoded
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# --- Environment ---
# development | staging | production
ENVIRONMENT=development
